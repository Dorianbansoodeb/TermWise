{
  "expo": {
    "name": "TermWise",
    "slug": "termwise",
    "scheme": "termwise",
    "version": "0.1.0",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "resizeMode": "contain",
      "backgroundColor": "#0f172a"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "app.termwise.mobile"
    },
    "android": {
      "package": "app.termwise.mobile",
      "adaptiveIcon": {
        "backgroundColor": "#0f172a"
      }
    },
    "assetBundlePatterns": ["**/*"]
  }
}
