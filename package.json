{
  "name": "student-finance-coop-planner",
  "private": true,
  "version": "1.0.0",
  "workspaces": [
    "backend",
    "mobile"
  ],
  "scripts": {
    "dev:backend": "npm run dev --workspace backend",
    "start:mobile": "npm run start --workspace mobile",
    "build:backend": "npm run build --workspace backend",
    "typecheck": "npm run lint --workspace backend && npm run typecheck --workspace mobile"
  }
}
{
  "name": "student-finance-mobile",
  "version": "1.0.0",
  "private": true,
  "main": "node_modules/expo/AppEntry.js",
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "expo": "~51.0.28",
    "expo-status-bar": "~1.12.1",
    "react": "18.2.0",
    "react-native": "0.74.5",
    "react-native-chart-kit": "^6.12.0",
    "react-native-safe-area-context": "4.10.5",
    "react-native-svg": "15.2.0"
  },
  "devDependencies": {
    "@types/react": "~18.2.79",
    "typescript": "^5.4.5"
  }
}
